---
interface Props {
  date: Date;
  /** Optional class to override styling */
  class?: string;
}
const { date, class: className } = Astro.props;
const formatted = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---
<time datetime={date.toISOString()} class={className}>{formatted}</time>

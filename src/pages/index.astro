---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";

const posts = await getCollection("posts", ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recent = posts.slice(0, 3);
---

<BaseLayout
  title="Cesar"
  description="PLACEHOLDER — replace with your real one-line site description before launch."
>
  <section>
    {/* EDIT BEFORE LAUNCH: the title + description above and the bio below are
        intentionally neutral placeholders. Do NOT ship them as-is. Cesar
        provides the real bio (1-3 sentences) and the final title/description.
        These are JSX comments ({}-wrapped) so they never appear in the
        published HTML. */}
    <h1 class="text-3xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
      Cesar
    </h1>
    <p class="mt-3 max-w-prose text-base leading-7 text-zinc-700 dark:text-zinc-300">
      One-to-three sentence bio goes here — who you are and what you write about.
      Replace this placeholder before launch.
    </p>
    <ul class="mt-5 flex flex-wrap gap-x-5 gap-y-1 text-sm">
      {/* EDIT BEFORE LAUNCH: replace the two REPLACE-ME URLs with your real
          handles. Decide whether to add X/Twitter or other links here too. */}
      <li>
        <a href="https://www.linkedin.com/in/REPLACE-ME" class="text-zinc-600 hover:text-accent dark:text-zinc-400" rel="me">LinkedIn</a>
      </li>
      <li>
        <a href="https://github.com/REPLACE-ME" class="text-zinc-600 hover:text-accent dark:text-zinc-400" rel="me">GitHub</a>
      </li>
      <li>
        <a href="mailto:cesar@caisar.ai" class="text-zinc-600 hover:text-accent dark:text-zinc-400">Email</a>
      </li>
    </ul>
  </section>

  {recent.length > 0 && (
    <section class="mt-16">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-zinc-500 dark:text-zinc-400">
        Latest writing
      </h2>
      <div class="mt-4">
        {recent.map((post) => <PostCard post={post} />)}
      </div>
      {posts.length > 3 && (
        <a
          href="/writing/"
          class="mt-6 inline-block text-sm text-zinc-600 hover:text-accent dark:text-zinc-400"
        >
          All posts →
        </a>
      )}
    </section>
  )}
</BaseLayout>

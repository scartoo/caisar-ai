---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="404 — caisar.ai"
  description="Page not found."
>
  <section class="text-center py-12">
    <p class="text-sm uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
      404
    </p>
    <h1 class="mt-2 text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
      Page not found
    </h1>
    <p class="mt-3 text-sm text-zinc-600 dark:text-zinc-400">
      Whatever you were looking for isn't here.
    </p>
    <div class="mt-6 flex justify-center gap-4 text-sm">
      <a href="/" class="text-zinc-600 hover:text-accent dark:text-zinc-400">Home</a>
      <span aria-hidden="true" class="text-zinc-300 dark:text-zinc-700">·</span>
      <a href="/writing/" class="text-zinc-600 hover:text-accent dark:text-zinc-400">Writing</a>
    </div>
  </section>
</BaseLayout>
